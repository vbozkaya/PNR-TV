    <!-- About App -->
    <string name="about_app_title">About App</string>
    <string name="about_app_info_title">App Information</string>
    <string name="about_app_name_label">App Name: PNR TV</string>
    <string name="about_app_version_label">Version: Version %1$s (Build %2$d)</string>
    <string name="about_app_version">Version %1$s (Build %2$d)</string>
    <string name="about_app_description">PNR TV - Smart Media Player is a professional media player application optimized specifically for Android TV interfaces. It delivers a smooth, intuitive, and cinematic experience for your video content, allowing you to manage and play your playlists with ease. PNR TV is not a content provider, but only a player; therefore, it does not host any media content, TV channels, or playlists.</string>
    <string name="about_legal_title">Important Legal Notice</string>
    <string name="about_legal_no_content">No Content Provided: Our application is not affiliated with any third-party IPTV provider and does not contain ready-made content.</string>
    <string name="about_legal_user_responsibility">User Responsibility: Users must obtain the content they wish to watch from legal service providers themselves.</string>
    <string name="about_legal_copyright">Copyright: PNR TV does not support or approve the publication of copyrighted materials without the permission of the copyright holder.</string>
    <string name="about_features_title">Features</string>
    <string name="about_features">Live Streams: Full support for live TV channels and categories.\n\nMovies &amp; Series (VOD): Movie categories, season/episode details and high-quality playback.\n\nMultiple Users &amp; Profiles: Manage multiple media service accounts and create separate viewer profiles for each user.\n\nSmart Tracking: Save favorite content, track recently watched, and resume from where you left off by saving playback position.</string>
    <string name="about_premium_features_title">Premium Advantages</string>
    <string name="about_premium_features">Ad-free Experience: Completely uninterrupted viewing.\n\nAdvanced Control: Adult content control, smart search and filtering options.\n\nProfile Management: Personalized user statuses and viewer profiles.</string>
    <string name="about_thanks_title">Thanks</string>
    <string name="about_thanks">Data Provider: We thank The Movie Database (TMDB) platform for movie and series data.\n\nInterface: Android TV Leanback Library is used for TV user interface components.\n\nCommunity: We thank all open source library developers for their contributions.</string>
    <string name="about_contact_title">Contact</string>
    <string name="about_contact_message">For collaboration, feedback and suggestions: tvpnrtv@gmail.com</string>
