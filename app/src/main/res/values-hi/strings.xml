    <string name="dialog_select_language_title">भाषा चुनें</string>
    <string name="dialog_clear_cache_title">सभी डेटा साफ करें</string>
    <string name="dialog_clear_cache_message">सभी डेटा (उपयोगकर्ता, पसंदीदा, देखने का इतिहास, सामग्री, आदि) हटा दिया जाएगा और ऐप नए स्थापित की तरह खुलेगा। यह कार्रवाई पूर्ववत नहीं की जा सकती। क्या आप जारी रखना चाहते हैं?</string>
