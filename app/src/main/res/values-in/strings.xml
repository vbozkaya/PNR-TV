    <!-- Tentang Aplikasi -->
    <string name="about_app_title">Tentang Aplikasi</string>
    <string name="about_app_description">PNR TV adalah aplikasi IPTV (Televisi Protokol Internet) yang dikembangkan khusus untuk platform Android TV. Memungkinkan pengguna untuk menonton siaran langsung, film, dan serial.</string>
    <string name="about_features_title">Fitur</string>
    <string name="about_features">• Film (VOD): Kategori film, detail, dan pemutaran\n• Serial: Kategori serial, musim, episode, dan pemutaran\n• Siaran Langsung: Saluran TV langsung dan kategori\n• Beberapa Pengguna: Manajemen beberapa akun IPTV\n• Profil Penonton: Profil penonton terpisah untuk setiap pengguna\n• Favorit: Simpan saluran favorit\n• Baru Ditonton: Lacak konten yang baru ditonton\n• Lanjutkan Pemutaran: Simpan posisi pemutaran</string>
    <string name="about_thanks_title">Terima Kasih</string>
    <string name="about_thanks">The Movie Database (TMDB) - Untuk data film dan serial\nAndroid TV Leanback Library - Untuk komponen UI TV\nSemua pengembang perpustakaan open source</string>
    <string name="about_contact_title">Kontak</string>
    <string name="about_contact_message">Untuk kolaborasi, umpan balik, dan saran, silakan kirim email kepada kami: tvpnrtv@gmail.com</string>
    <string name="about_contact_email">tvpnrtv@gmail.com</string>
    <string name="about_contact_email_subject">PNR TV - Kontak</string>
    <string name="dialog_select_language_title">Pilih Bahasa</string>
    <string name="dialog_clear_cache_title">Hapus Semua Data</string>
    <string name="dialog_clear_cache_message">Semua data (pengguna, favorit, riwayat tontonan, konten, dll.) akan dihapus dan aplikasi akan terbuka seperti baru diinstal. Tindakan ini tidak dapat dibatalkan. Apakah Anda ingin melanjutkan?</string>
