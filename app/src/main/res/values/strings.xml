    <!-- About App -->
    <string name="about_app_title">Uygulama Hakkında</string>
    <string name="about_app_description">PNR TV, Android TV platformu için geliştirilmiş bir IPTV (İnternet Protokolü Televizyonu) uygulamasıdır. Kullanıcıların canlı yayınları, filmleri ve dizileri izlemesine olanak tanır.</string>
    <string name="about_features_title">Özellikler</string>
    <string name="about_features">• Filmler (VOD): Film kategorileri, detaylar ve oynatma\n• Diziler: Dizi kategorileri, sezonlar, bölümler ve oynatma\n• Canlı Yayınlar: Canlı TV kanalları ve kategorileri\n• Çoklu Kullanıcı: Birden fazla IPTV hesabı yönetimi\n• İzleyici Profilleri: Her kullanıcı için ayrı izleyici profilleri\n• Favoriler: Favori kanalları kaydetme\n• Son İzlenenler: Son izlenen içerikleri takip etme\n• Kaldığınız Yerden Devam: Oynatma pozisyonu kaydetme</string>
    <string name="about_thanks_title">Teşekkürler</string>
    <string name="about_thanks">The Movie Database (TMDB) - Film ve dizi verileri için\nAndroid TV Leanback Library - TV UI bileşenleri için\nTüm açık kaynak kütüphane geliştiricilerine</string>
    <string name="about_contact_title">İletişim</string>
    <string name="about_contact_message">İş birliği, görüş ve önerileriniz için lütfen bize mail atınız: tvpnrtv@gmail.com</string>
    <string name="about_contact_email">tvpnrtv@gmail.com</string>
    <string name="about_contact_email_subject">PNR TV - İletişim</string>
    
