<?xml version="1.0" encoding="utf-8"?>
<!-- Odaklanmış Oynat butonu için parlayan çerçeve efekti -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    
    <!-- Outer Glow - Dış ışıma efekti (3 katmanlı yumuşak geçiş) -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="16dp" />
            <solid android:color="#4000D9FF" />  <!-- Elektrik mavisi, %25 opacity -->
        </shape>
    </item>
    
    <item android:left="2dp" android:top="2dp" android:right="2dp" android:bottom="2dp">
        <shape android:shape="rectangle">
            <corners android:radius="15dp" />
            <solid android:color="#6000D9FF" />  <!-- %38 opacity -->
        </shape>
    </item>
    
    <item android:left="4dp" android:top="4dp" android:right="4dp" android:bottom="4dp">
        <shape android:shape="rectangle">
            <corners android:radius="14dp" />
            <solid android:color="#8000D9FF" />  <!-- %50 opacity -->
        </shape>
    </item>
    
    <!-- Parlayan çerçeve -->
    <item android:left="6dp" android:top="6dp" android:right="6dp" android:bottom="6dp">
        <shape android:shape="rectangle">
            <corners android:radius="12dp" />
            <stroke 
                android:width="3dp" 
                android:color="#00D9FF" />  <!-- Canlı turkuaz çerçeve -->
            <solid android:color="#CC1A1A2E" />  <!-- Koyu arka plan -->
        </shape>
    </item>
    
</layer-list>




