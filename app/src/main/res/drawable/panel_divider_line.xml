<?xml version="1.0" encoding="utf-8"?>
<!-- Oynatma alanı içindeki bölücü çizgi - parlak mavi, kenarlarda kaybolan -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Parlak mavi çizgi - kenarlarda şeffaflaşarak kaybolan -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="0"
                android:startColor="#0000D9FF"
                android:centerColor="#FF00D9FF"
                android:endColor="#0000D9FF" />
            <size android:height="2dp" />
        </shape>
    </item>
</layer-list>

