<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Şeffaf arka plan -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#00000000" />
        </shape>
    </item>
    
    <!-- Mavi blurlu çerçeve - dış glow -->
    <item android:top="-1dp" android:bottom="-1dp" android:left="-1dp" android:right="-1dp">
        <shape android:shape="rectangle">
            <solid android:color="#00000000" />
            <stroke
                android:width="1dp"
                android:color="#33B3E5FF" />
        </shape>
    </item>
    
    <!-- Mavi blurlu çerçeve - ana çizgi -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#00000000" />
            <stroke
                android:width="2dp"
                android:color="#66B3E5FF" />
        </shape>
    </item>
    
    <!-- Mavi blurlu çerçeve - iç glow -->
    <item android:top="1dp" android:bottom="1dp" android:left="1dp" android:right="1dp">
        <shape android:shape="rectangle">
            <solid android:color="#00000000" />
            <stroke
                android:width="1dp"
                android:color="#33B3E5FF" />
        </shape>
    </item>
</layer-list>

