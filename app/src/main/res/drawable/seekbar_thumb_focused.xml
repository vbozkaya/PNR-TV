<?xml version="1.0" encoding="utf-8"?>
<!-- SeekBar topu focus aldığında - mavi border ile, ince -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Mavi dış border -->
    <item>
        <shape android:shape="oval">
            <solid android:color="#00D9FF" />
            <size
                android:width="14dp"
                android:height="14dp" />
        </shape>
    </item>
    
    <!-- İç beyaz top -->
    <item
        android:left="3dp"
        android:right="3dp"
        android:top="3dp"
        android:bottom="3dp">
        <shape android:shape="oval">
            <solid android:color="#FFFFFF" />
        </shape>
    </item>
</layer-list>

