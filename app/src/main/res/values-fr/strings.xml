    <!-- À Propos de l\'Application -->
    <string name="about_app_title">À Propos de l\'Application</string>
    <string name="about_app_info_title">Informations sur l\'Application</string>
    <string name="about_app_name_label">Nom de l\'Application: PNR TV</string>
    <string name="about_app_version_label">Version: Version %1$s (Build %2$d)</string>
    <string name="about_app_version">Version %1$s (Build %2$d)</string>
    <string name="about_app_description">PNR TV - Lecteur Média Intelligent est une application professionnelle de lecteur média optimisée spécifiquement pour les interfaces Android TV. Il offre une expérience fluide, intuitive et cinématographique pour votre contenu vidéo, vous permettant de gérer et de lire vos listes de lecture en toute simplicité. PNR TV n\'est pas un fournisseur de contenu, mais seulement un lecteur; par conséquent, il n\'héberge aucun contenu multimédia, chaînes de télévision ou listes de lecture.</string>
    <string name="about_legal_title">Avis Juridique Important</string>
    <string name="about_legal_no_content">Aucun Contenu Fourni: Notre application n\'est affiliée à aucun fournisseur IPTV tiers et ne contient pas de contenu prêt à l\'emploi.</string>
    <string name="about_legal_user_responsibility">Responsabilité de l\'Utilisateur: Les utilisateurs doivent obtenir le contenu qu\'ils souhaitent regarder auprès de fournisseurs de services légaux eux-mêmes.</string>
    <string name="about_legal_copyright">Droits d\'Auteur: PNR TV ne soutient ni n\'approuve la publication de matériel protégé par le droit d\'auteur sans l\'autorisation du titulaire des droits d\'auteur.</string>
    <string name="about_features_title">Caractéristiques</string>
    <string name="about_features">Diffusions en Direct: Support complet pour les chaînes de télévision en direct et les catégories.\n\nFilms &amp; Séries (VOD): Catégories de films, détails de saison/épisode et lecture de haute qualité.\n\nUtilisateurs Multiples &amp; Profils: Gérer plusieurs comptes de service média et créer des profils de spectateur séparés pour chaque utilisateur.\n\nSuivi Intelligent: Enregistrer le contenu favori, suivre récemment regardé et reprendre là où vous vous êtes arrêté en enregistrant la position de lecture.</string>
    <string name="about_premium_features_title">Avantages Premium</string>
    <string name="about_premium_features">Expérience sans Publicité: Visualisation complètement ininterrompue.\n\nContrôle Avancé: Contrôle du contenu pour adultes, options de recherche et de filtrage intelligentes.\n\nGestion des Profils: Statuts d\'utilisateur personnalisés et profils de spectateur.</string>
    <string name="about_thanks_title">Remerciements</string>
    <string name="about_thanks">Fournisseur de Données: Nous remercions la plateforme The Movie Database (TMDB) pour les données de films et séries.\n\nInterface: Android TV Leanback Library est utilisée pour les composants d\'interface utilisateur TV.\n\nCommunauté: Nous remercions tous les développeurs de bibliothèques open source pour leurs contributions.</string>
    <string name="about_contact_title">Contact</string>
    <string name="about_contact_message">Pour la collaboration, les commentaires et les suggestions: tvpnrtv@gmail.com</string>
    <string name="dialog_select_language_title">Sélectionner la Langue</string>
    <string name="dialog_clear_cache_title">Effacer Toutes les Données</string>
    <string name="dialog_clear_cache_message">Toutes les données (utilisateurs, favoris, historique de visionnage, contenu, etc.) seront supprimées et l\'application s\'ouvrira comme si elle venait d\'être installée. Cette action ne peut pas être annulée. Voulez-vous continuer?</string>
