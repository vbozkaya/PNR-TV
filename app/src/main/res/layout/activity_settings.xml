<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/home_background"
    android:fitsSystemWindows="true">
    
    <include
        android:id="@+id/navbar"
        layout="@layout/layout_navbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />
    
    <LinearLayout
        android:id="@+id/layout_settings_content"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:orientation="vertical"
        android:paddingStart="32dp"
        android:paddingEnd="32dp"
        app:layout_constraintTop_toBottomOf="@id/navbar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/btn_user_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/second_focus_selector"
            android:padding="24dp"
            android:text="@string/settings_user_status"
            android:textColor="@android:color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            android:focusable="true"
            android:clickable="true"
            android:focusableInTouchMode="true"
            android:gravity="center_vertical" />

        <TextView
            android:id="@+id/btn_app_language"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/second_focus_selector"
            android:padding="24dp"
            android:text="@string/settings_app_language"
            android:textColor="@android:color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            android:focusable="true"
            android:clickable="true"
            android:focusableInTouchMode="true"
            android:gravity="center_vertical" />

        <TextView
            android:id="@+id/btn_viewers"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/second_focus_selector"
            android:padding="24dp"
            android:text="@string/page_viewers"
            android:textColor="@android:color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            android:focusable="true"
            android:clickable="true"
            android:focusableInTouchMode="true"
            android:gravity="center_vertical" />

        <TextView
            android:id="@+id/btn_clear_cache"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/second_focus_selector"
            android:padding="24dp"
            android:text="@string/settings_clear_cache"
            android:textColor="@android:color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            android:focusable="true"
            android:clickable="true"
            android:focusableInTouchMode="true"
            android:gravity="center_vertical" />

    </LinearLayout>
    
</androidx.constraintlayout.widget.ConstraintLayout>

