<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="@drawable/episode_item_selector"
    android:clickable="true"
    android:focusable="true"
    android:paddingHorizontal="24dp"
    android:paddingVertical="16dp"
    android:gravity="center_vertical">

    <!-- Bölüm Numarası -->
    <TextView
        android:id="@+id/txt_episode_number"
        android:layout_width="48dp"
        android:layout_height="wrap_content"
        android:textColor="#CCCCCC"
        android:textSize="18sp"
        android:textStyle="bold"
        android:gravity="center"
        tools:text="01" />

    <!-- Bölüm Bilgileri (Başlık + Alt Bilgiler) -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="16dp"
        android:orientation="vertical">

        <!-- Bölüm Başlığı -->
        <TextView
            android:id="@+id/txt_episode_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@android:color/white"
            android:textSize="20sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"
            tools:text="Pilot Bölümü" />

        <!-- Bölüm Meta Bilgileri (Süre + Tarih) -->
        <LinearLayout
            android:id="@+id/layout_episode_meta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:orientation="horizontal"
            android:visibility="gone"
            tools:visibility="visible">

            <!-- Süre -->
            <TextView
                android:id="@+id/txt_episode_duration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#999999"
                android:textSize="14sp"
                tools:text="47 dk" />

            <!-- Ayırıcı -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                android:text="@string/bullet_symbol"
                android:textColor="#666666"
                android:textSize="14sp" />

            <!-- Tarih -->
            <TextView
                android:id="@+id/txt_episode_date"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="#999999"
                android:textSize="14sp"
                android:maxLines="1"
                android:ellipsize="end"
                tools:text="20 Ocak 2008" />

        </LinearLayout>

    </LinearLayout>

    <!-- İzlenme Durumu İkonu (Opsiyonel) -->
    <ImageView
        android:id="@+id/img_episode_watched"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_marginStart="16dp"
        android:src="@android:drawable/checkbox_on_background"
        android:contentDescription="@string/cd_episode_watched"
        android:visibility="gone"
        tools:visibility="visible" />

</LinearLayout>
