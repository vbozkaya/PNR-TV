<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1a1a1a">

    <!-- Navbar -->
    <include
        android:id="@+id/navbar"
        layout="@layout/layout_navbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:elevation="24dp"
        android:translationZ="24dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Sol taraf: Kategoriler (ekranın 1/6'sı) -->
    <FrameLayout
        android:id="@+id/category_list_container"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/navbar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintWidth_percent="0.208">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_categories"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingStart="16dp"
            android:paddingTop="16dp"
            android:paddingEnd="8dp"
            android:paddingBottom="16dp"
            android:clipChildren="false"
            android:clipToPadding="false" />

    </FrameLayout>

    <!-- Ayırıcı çizgi -->
    <View
        android:id="@+id/divider"
        android:layout_width="2dp"
        android:layout_height="0dp"
        android:background="@drawable/divider_gradient"
        app:layout_constraintStart_toEndOf="@id/category_list_container"
        app:layout_constraintTop_toBottomOf="@id/navbar"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- Sağ taraf: İçerik alanı (ekranın 5/6'sı) -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_series"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:padding="16dp"
        android:clipToPadding="false"
        android:elevation="0dp"
        app:layout_constraintStart_toEndOf="@id/divider"
        app:layout_constraintTop_toBottomOf="@id/navbar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- Boş durum bilgilendirme mesajı -->
    <LinearLayout
        android:id="@+id/empty_state_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone"
        app:layout_constraintStart_toStartOf="@id/recycler_series"
        app:layout_constraintEnd_toEndOf="@id/recycler_series"
        app:layout_constraintTop_toTopOf="@id/recycler_series"
        app:layout_constraintBottom_toBottomOf="@id/recycler_series">

        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/ic_empty_state"
            android:contentDescription="@string/cd_empty_state_icon"
            android:layout_marginBottom="24dp" />

        <TextView
            android:id="@+id/txt_empty_state"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="24sp"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:gravity="center"
            android:maxWidth="600dp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>

