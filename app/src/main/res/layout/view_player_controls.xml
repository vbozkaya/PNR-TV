<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/player_controls_background"
    android:focusable="false"
    android:focusableInTouchMode="false"
    android:descendantFocusability="beforeDescendants">
    
    <!-- Bölücü çizgi - oynatma alanını üst ve alt kısma ayırır -->
    <View
        android:id="@+id/panel_divider"
        android:layout_width="0dp"
        android:layout_height="4dp"
        android:background="@drawable/panel_divider_line"
        android:layout_marginStart="0dp"
        android:layout_marginEnd="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.25" />
    
    <!-- ÜST KISIM: Film/Dizi adı ve IMDB puanı -->
    <FrameLayout
        android:id="@+id/panelTopSection"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:paddingStart="40dp"
        android:paddingEnd="40dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/panel_divider"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">
        
        <!-- Film/Dizi adı ve IMDB puanı -->
        <TextView
            android:id="@+id/txtContentTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical|start"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"
            android:text="" />
        
    </FrameLayout>
    
    <!-- ALT KISIM: SeekBar ve zaman göstergeleri -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/panelBottomSection"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        app:layout_constraintTop_toBottomOf="@id/panel_divider"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">
        
        <!-- Guideline'lar - Butonların eşit aralıklarla yerleşmesi için (5 buton için 6 eşit bölüm) -->
        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/guideline_btn1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_percent="0.1" />
        
        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/guideline_btn2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_percent="0.3" />
        
        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/guideline_btn3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_percent="0.5" />
        
        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/guideline_btn4"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_percent="0.7" />
        
        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/guideline_btn5"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_percent="0.9" />
        
        <!-- SeekBar - tam genişlikte -->
        <SeekBar
            android:id="@+id/seekbar_progress"
            android:layout_width="0dp"
            android:layout_height="9dp"
            android:progressDrawable="@drawable/seekbar_progress_with_watched"
            android:thumb="@drawable/seekbar_thumb_selector"
            android:max="100"
            android:progress="0"
            android:secondaryProgress="0"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:minHeight="9dp"
            android:maxHeight="9dp"
            android:background="@android:color/transparent"
            android:layout_marginTop="30dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
        
        <!-- Geçen süre - SeekBar'ın üstünde, sol -->
        <TextView
            android:id="@+id/txtCurrentTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="00:00"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"
            app:layout_constraintStart_toStartOf="@id/seekbar_progress"
            app:layout_constraintBottom_toTopOf="@id/seekbar_progress" />
        
        <!-- Toplam süre - SeekBar'ın üstünde, sağ -->
        <TextView
            android:id="@+id/txtTotalTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="00:00"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"
            app:layout_constraintEnd_toEndOf="@id/seekbar_progress"
            app:layout_constraintBottom_toTopOf="@id/seekbar_progress" />
        
        <!-- Butonlar satırı - Guideline'lara göre eşit aralıklarla yerleştirilmiş -->
        <!-- Play Butonu - Video durdurulmuşsa görünür -->
        <ImageButton
            android:id="@+id/btn_play"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:minWidth="48dp"
            android:minHeight="48dp"
            android:src="@drawable/ic_play"
            android:background="@drawable/button_focus_background"
            android:contentDescription="@string/cd_play"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:visibility="gone"
            android:padding="0dp"
            android:layout_marginBottom="16dp"
            android:nextFocusLeft="@id/btn_subtitle"
            android:nextFocusRight="@id/btn_backward"
            android:nextFocusUp="@id/seekbar_progress"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="@id/guideline_btn1"
            app:layout_constraintEnd_toEndOf="@id/guideline_btn1" />
        
        <!-- Stop Butonu - Video oynatılıyorsa görünür (Play ile aynı constraint'ler) -->
        <ImageButton
            android:id="@+id/btnStop"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:minWidth="48dp"
            android:minHeight="48dp"
            android:src="@drawable/ic_stop"
            android:background="@drawable/button_focus_background"
            android:contentDescription="@string/cd_stop"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:visibility="gone"
            android:padding="0dp"
            android:layout_marginBottom="16dp"
            android:nextFocusLeft="@id/btn_subtitle"
            android:nextFocusRight="@id/btn_backward"
            android:nextFocusUp="@id/seekbar_progress"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="@id/guideline_btn1"
            app:layout_constraintEnd_toEndOf="@id/guideline_btn1" />
        
        <!-- Backward Butonu -->
        <ImageButton
            android:id="@+id/btn_backward"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_backward"
            android:background="@drawable/button_focus_background"
            android:contentDescription="@string/cd_rewind"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:padding="0dp"
            android:layout_marginBottom="16dp"
            android:nextFocusLeft="@id/btn_play"
            android:nextFocusRight="@id/btn_forward"
            android:nextFocusUp="@id/seekbar_progress"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="@id/guideline_btn2"
            app:layout_constraintEnd_toEndOf="@id/guideline_btn2" />
        
        <!-- Forward Butonu -->
        <ImageButton
            android:id="@+id/btn_forward"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_forward"
            android:background="@drawable/button_focus_background"
            android:contentDescription="@string/cd_fast_forward"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:padding="0dp"
            android:layout_marginBottom="16dp"
            android:nextFocusRight="@id/btn_speak"
            android:nextFocusLeft="@id/btn_backward"
            android:nextFocusUp="@id/seekbar_progress"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="@id/guideline_btn3"
            app:layout_constraintEnd_toEndOf="@id/guideline_btn3" />
        
        <!-- Ses Butonu -->
        <ImageButton
            android:id="@+id/btn_speak"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/speak"
            android:background="@drawable/button_focus_background"
            android:contentDescription="@string/cd_audio_track"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:padding="0dp"
            android:layout_marginBottom="16dp"
            android:nextFocusRight="@id/btn_subtitle"
            android:nextFocusLeft="@id/btn_forward"
            android:nextFocusUp="@id/seekbar_progress"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="@id/guideline_btn4"
            app:layout_constraintEnd_toEndOf="@id/guideline_btn4" />
        
        <!-- Alt Yazı Butonu - En sonda -->
        <ImageButton
            android:id="@+id/btn_subtitle"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/subtitle"
            android:background="@drawable/button_focus_background"
            android:contentDescription="@string/cd_subtitle"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:padding="0dp"
            android:layout_marginBottom="16dp"
            android:nextFocusRight="@id/btn_play"
            android:nextFocusLeft="@id/btn_speak"
            android:nextFocusUp="@id/seekbar_progress"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="@id/guideline_btn5"
            app:layout_constraintEnd_toEndOf="@id/guideline_btn5" />
        
    </androidx.constraintlayout.widget.ConstraintLayout>
    
</androidx.constraintlayout.widget.ConstraintLayout>
