<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_marginTop="8dp"
    android:layout_marginEnd="12dp"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:minWidth="150dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_user_card"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:focusable="true"
        android:focusableInTouchMode="true"
        android:clickable="true">

        <ImageView
            android:id="@+id/ivUserIcon"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:contentDescription="@string/page_users_list"
            android:src="@drawable/ic_current_users" />

        <TextView
            android:id="@+id/tvAccountLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/label_account_name"
            android:textColor="@android:color/white"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvAccountValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="@android:color/white"
            android:textSize="20sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingBottom="4dp">

        <ImageButton
            android:id="@+id/btnSelectUser"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_icon_focus"
            android:contentDescription="@string/cd_select_user"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:padding="4dp"
            android:src="@drawable/ic_check"
            app:tint="@android:color/white" />

        <ImageButton
            android:id="@+id/btnEditUser"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginStart="12dp"
            android:background="@drawable/bg_icon_focus"
            android:contentDescription="@string/cd_edit_user"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:padding="4dp"
            android:src="@drawable/ic_edit"
            app:tint="@android:color/white" />

        <ImageButton
            android:id="@+id/btnDeleteUser"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginStart="12dp"
            android:background="@drawable/bg_icon_focus"
            android:contentDescription="@string/cd_delete_user"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:padding="4dp"
            android:src="@drawable/ic_delete"
            app:tint="@android:color/white" />
    </LinearLayout>

</LinearLayout>

